// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  phone    String?

  level          Int @default(1)
  currentExp     Int @default(0)
  expToNextLevel Int @default(100)
  totalExp       Int @default(0)

  questFolders QuestFolder[]
  reflections  Reflection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuestFolder {
  id          String       @id @default(uuid())
  name        String
  description String?      @db.Text
  status      FolderStatus @default(PENDING)

  userId String
  user   User    @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  quests Quest[]

  createdAt DateTime @default(now())
  endedAt   DateTime
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

enum FolderStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

model Quest {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  expReward   Int     @default(10) // 10 EXP
  isSuccess   Boolean @default(false)

  folderId   String
  folder     QuestFolder       @relation(fields: [folderId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  reflection QuestReflection[]

  createdAt   DateTime  @default(now())
  deadLineAt  DateTime
  completedAt DateTime?

  @@unique([folderId, name])
}

model QuestReflection {
  id String @id @default(uuid())

  questLevel QuestLevel @default(LOW)
  reason     String
  questId    String     @unique
  quest      Quest      @relation(fields: [questId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum QuestLevel {
  LOW
  NORMAL
  HIGH
}

model Reflection {
  id      String @id @default(uuid())
  content String @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt   DateTime  @default(now())
  startPeriod DateTime?
  endPeriod   DateTime?
}
