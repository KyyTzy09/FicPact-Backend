generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String?
  phone    String?

  isVerified Boolean @default(false)

  verificationToken       String?   @db.VarChar(6)
  verificationTokenExpiry DateTime?

  resetPasswordToken  String?   @db.Text
  resetPasswordExpiry DateTime?

  level          Int      @default(1)
  currentExp     Int      @default(0)
  expToNextLevel Int      @default(100)
  totalExp       Int      @default(0)
  lastReflection DateTime @default(now())

  questFolders       QuestFolder[]
  reflections        Reflection[]
  reflectionTriggers ReflectionTrigger[]
  userAchievements   UserAchievement[]
  //profile     Profile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

