model Achievement {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  expReward   Int      @default(0) // optional EXP reward
  criteria    String?  // contoh: "Reach level 5" atau "Complete 10 quests"
  
  users UserAchievement[] // relasi many-to-many ke user

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
}


model UserAchievement {
  id            String      @id @default(uuid())
  userId        String
  achievementId String
  achievedAt    DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@unique([userId, achievementId])
}

model QuestFolder {
  id          String       @id @default(uuid())
  name        String
  icon        String?
  color       String?      @db.Text
  description String?      @db.Text
  status      FolderStatus @default(PENDING)

  userId String
  user   User    @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  quests Quest[]

  createdAt DateTime  @default(now())
  endedAt   DateTime?
  updatedAt DateTime  @updatedAt

  @@unique([userId, name])
}

enum FolderStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

model Quest {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  expReward   Int     @default(10) // 10 EXP
  isSuccess   Boolean @default(false)

  folderId   String
  folder     QuestFolder       @relation(fields: [folderId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  reflection QuestReflection[]

  createdAt   DateTime  @default(now())
  deadLineAt  DateTime
  completedAt DateTime?

  @@unique([folderId, name])
}

model QuestReflection {
  id String @id @default(uuid())

  questLevel QuestLevel          @default(LOW)
  reason     String
  type       QuestReflectionType
  questId    String
  quest      Quest               @relation(fields: [questId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([questId, reason])
}

enum QuestLevel {
  LOW
  NORMAL
  HIGH
}

enum QuestReflectionType {
  SUCCESS
  FAILED
}

model Reflection {
  id      String @id @default(uuid())
  content String @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt   DateTime  @default(now())
  startPeriod DateTime?
  endPeriod   DateTime?
}

model ReflectionTrigger {
  id           String  @id @default(uuid())
  isReflection Boolean @default(false)
  userId       String
  user         User    @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
