generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  phone    String?

  questFolders QuestFolder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuestFolder {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text

  userId      String
  user        User         @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  quests      Quest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model Quest {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text

  isSuccess Boolean @default(false)

  folderId String
  folder   QuestFolder @relation(fields: [folderId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  createdAt   DateTime  @default(now())
  deadLineAt  DateTime
  completedAt DateTime?

  @@unique([folderId, name])
}

